# Telegram API credentials
# Get these from https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Bot token for notifications
# Create a bot via @BotFather on Telegram
BOT_TOKEN=

# Your Telegram user ID (the bot sends alerts here)
# Find it by messaging @userinfobot on Telegram
BOT_NOTIFY_USER_ID=

# Chat types to monitor: comma-separated
# Options: PRIVATE, GROUP, CHANNEL
MONITORED_TYPES=PRIVATE,GROUP

# Additional specific chat IDs to monitor (comma-separated, optional)
# Find IDs by running: python get_chat_ids.py
MONITORED_CHATS=
